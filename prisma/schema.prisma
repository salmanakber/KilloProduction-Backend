  experienceYears   Int?
  certification     String? // Certification name if any
  isPrimary         Boolean  @default(false) // Primary specialization
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  mechanicProfile MechanicProfile @relation(fields: [mechanicProfileId], references: [id], onDelete: Cascade)

  @@index([mechanicProfileId])
  @@index([expertiseType])
  @@map("mechanic_expertise")
}

model MechanicServiceRequest {
  id                       String                @id @default(cuid())
  customerId               String
  mechanicId               String? // Null if not assigned yet
  vehicleCheckId           String? // Reference to vehicle check/analysis
  vehicleMake              String
  vehicleModel             String
  vehicleYear              String?
  vehicleVariant           String?
  metadata                 Json?
  mileage                  Int?
  issueDescription         String
  diagnosedIssues          Json // AI diagnosis results
  recommendedParts         Json // AI recommended parts list
  recommendedMechanicTypes Json? // Types of mechanics needed
  carHealthScore           Float? // 0-100 score from AI
  images                   Json? // Array of image URLs
  customerLatitude         Float?
  customerLongitude        Float?
  customerAddress          String?
  customerCity             String?
  type                     MechanicServiceType   @default(ONLY_SERVICE) // ONLY_SERVICE direct contact or preper by ai report OR PICK_DELIVREY_AND_SERVICE preper by part request 
  status                   MechanicServiceStatus @default(PENDING)
  urgency                  UrgencyLevel          @default(MEDIUM)
  expiresAt                DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  customer      User                   @relation("CustomerServiceRequests", fields: [customerId], references: [id], onDelete: Cascade)
  mechanic      MechanicProfile?       @relation("MechanicServiceRequests", fields: [mechanicId], references: [id], onDelete: SetNull)
  offers        MechanicOffer[]
  notifications MechanicNotification[]
  quote         MechanicQuote?         @relation("QuoteServiceRequests")

  @@index([customerId])
  @@index([mechanicId])
  @@index([status])
  @@index([customerCity])
  @@map("mechanic_service_requests")
}

model MechanicOffer {
  id               String              @id @default(cuid())
  serviceRequestId String
  mechanicId       String
  partsList        Json // Array of parts with quantities and prices
  serviceCharges   Float // Labor/service charges
  diagnosticFee    Float? // Diagnostic fee if applicable
  totalAmount      Float // Total (parts + service + diagnostic)
  estimatedTime    String? // e.g., "2-3 hours", "1 day"
  warranty         String? // Warranty information
  notes            String? // Additional notes from mechanic
  status           MechanicOfferStatus @default(PENDING)
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  serviceRequest MechanicServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  mechanic       User                   @relation("MechanicOffers", fields: [mechanicId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([mechanicId])
  @@index([status])
  @@map("mechanic_offers")
}

model MechanicNotification {
  id               String    @id @default(cuid())
