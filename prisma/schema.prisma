enum MoneyTransferStatus {
  PENDING // Payment initiated, waiting for Stripe confirmation
  PROCESSING // Stripe payment succeeded, processing Paystack payout
  SENT // Paystack payout initiated successfully
  COMPLETED // Paystack payout completed
  FAILED // Payment or payout failed
  CANCELLED // Transfer cancelled by sender or system
  REFUNDED // Admin or gateway refund completed
}

enum MoneyTransferCaseType {
  REFUND_REQUEST
  DISPUTE
  PAYOUT_ISSUE
  FRAUD_REVIEW
  MANUAL_REVIEW
  OTHER
}

enum MoneyTransferPayoutStatus {
  PENDING // Payout created, waiting for Paystack processing
  PROCESSING // Paystack is processing the transfer
  SUCCESS // Payout completed successfully
  FAILED // Payout failed
  REVERSED // Payout was reversed
}

/// How inbound transfers settle after sender payment succeeds.
enum MoneyTransferSettlementMode {
  WALLET // Credit receiver's money-transfer wallet (withdraw to bank separately)
  DIRECT_BANK // Legacy: auto Paystack payout to receiver bank on payment success
}

enum MoneyTransferWalletTxType {
  CREDIT
  DEBIT
  WITHDRAWAL
  ADJUSTMENT
}

enum MoneyWalletWithdrawalStatus {
  PENDING
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REJECTED
}

model MoneyTransfer {
  id           String              @id @default(cuid())
  senderId     String
  receiverId   String
  amount       Float // Amount in sender's currency
  currency     String              @default("USD")
  ngnAmount    Float? // Converted amount in NGN for payout (legacy + compatibility)
  exchangeRate Float? // Customer-facing / locked conversion rate (send → settlement), mirrors customerRate when set
  status       MoneyTransferStatus @default(PENDING)

  /// Locked at create — recipient settlement amount (e.g. NGN)
  receiveAmount   Float?
  receiveCurrency String? @default("NGN")
  /// Reporting standard from SystemSettings.currency at transaction time
  baseCurrency String?
  baseAmount   Float?
  /// Mid-market vs offered rate (audit)
  midMarketRate    Float?
  customerRate     Float?
  markupPercentage Float?
  rateSource       String?
  /// Service fee in send currency / base (taxable platform revenue includes feeBase + fxMarginBase)
  fee     Float?
  feeBase Float?
  /// FX spread profit in settlement currency and in base (platform earnings)
  fxMarginSettlement Float?
  fxMarginBase       Float?

  // Stripe payment details
  stripePaymentIntentId String? @unique
  stripeClientSecret    String?
  stripeAmount          Int? // Amount in cents

  // Receiver bank details (for Paystack payout)
  receiverBankName      String?
  receiverAccountNumber String?
  receiverAccountName   String?
  receiverBankCode      String? // Paystack bank code

  // Metadata
  description String?
  reference   String  @unique @default(cuid())
  metadata    Json?

  receiptImageUrl             String?
  receiptCloudinaryPublicId   String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sentAt      DateTime?
  completedAt DateTime?
  failedAt    DateTime?

  /// Sender choice: credit receiver wallet or pay out to bank immediately.
  settlementMode MoneyTransferSettlementMode @default(WALLET)

  // Relations
  sender   User                 @relation("MoneyTransferSender", fields: [senderId], references: [id])
  receiver User                 @relation("MoneyTransferReceiver", fields: [receiverId], references: [id])
  payout   MoneyTransferPayout?
  walletTransactions MoneyTransferWalletTransaction[]
  supportCases       MoneyTransferCase[]

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([reference])
  @@index([stripePaymentIntentId])
  @@map("money_transfers")
}

model MoneyTransferPayout {
  id         String                    @id @default(cuid())
  transferId String                    @unique
  status     MoneyTransferPayoutStatus @default(PENDING)

  // Paystack transfer details
  paystackTransferCode  String? @unique
  paystackRecipientCode String? // Paystack recipient code
  paystackReference     String? @unique

  // Amount details
  amount   Float // Amount in NGN (kobo)
  currency String @default("NGN")

  // Bank account details
  bankName      String
  accountNumber String
  accountName   String
  bankCode      String // Paystack bank code

  // Error handling
  failureReason String?
  retryCount    Int       @default(0)
  lastRetryAt   DateTime?

  // Metadata
  paystackResponse Json?
  metadata         Json?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
  completedAt DateTime?
  failedAt    DateTime?

  // Relations
  transfer MoneyTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([paystackTransferCode])
  @@index([paystackReference])
  @@map("money_transfer_payouts")
}

model MoneyTransferConfig {
  id String @id @default(cuid())

  // Stripe configuration (separate from marketplace)
  stripeSecretKey      String?
  stripePublishableKey String?
  stripeWebhookSecret  String?

  // Paystack configuration (separate from marketplace)
  paystackSecretKey String?
  paystackPublicKey String?

  // Module settings
  isEnabled           Boolean  @default(true)
  minTransferAmount   Float    @default(1.0)
  maxTransferAmount   Float    @default(10000.0)
  defaultCurrency     String   @default("USD")
  supportedCurrencies String[] @default(["USD", "NGN"])

  // Exchange rate settings
  exchangeRateProvider String? // e.g., "fixer", "openexchangerates"
  exchangeRateApiKey   String?
  exchangeRateMargin   Float   @default(0.02) // 2% margin

  // Fees
  transferFeePercentage Float @default(0.0)
  transferFeeFixed      Float @default(0.0)

  /// WALLET = credit receiver wallet; DIRECT_BANK = immediate Paystack payout (legacy).
  settlementMode MoneyTransferSettlementMode @default(WALLET)

  /// When true, wallet withdrawal requests auto-send to bank after delay (see autoPayoutDelayMinutes).
  autoPayoutEnabled      Boolean @default(false)
  autoPayoutDelayMinutes Int     @default(12)

  /// After this many minutes in PENDING, worker may auto-run Paystack payout (NGN only) if liquidity allows.
  withdrawalSmartAutoApprove           Boolean @default(false)
  withdrawalSmartApproveDelayMinutes    Int     @default(15)
  /// Minimum Paystack NGN balance to keep before smart auto-approvals run (major units).
  withdrawalPaystackBufferNgn          Float   @default(50000)
  /// NGN payouts at or below this amount use a 1-minute delay when autoPayoutEnabled (optional instant-ish path).
  withdrawalInstantMaxNgn               Float?

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("money_transfer_config")
}

/// Separate from marketplace `Wallet` — used only for Kilo money transfers (one row per currency).
model MoneyTransferWallet {
  id        String   @id @default(cuid())
  userId    String
  currency  String   @default("NGN")
  balance   Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions MoneyTransferWalletTransaction[]

  @@unique([userId, currency])
  @@index([userId])
  @@map("money_transfer_wallets")
}

model MoneyTransferWalletTransaction {
  id           String                      @id @default(cuid())
  walletId     String
  userId       String
  type         MoneyTransferWalletTxType
  amount       Float
  balanceAfter Float
  currency     String                      @default("NGN")
  description  String
  reference    String?                     @unique
  transferId   String?
  payoutId     String?
  metadata     Json?
  createdAt    DateTime                    @default(now())

  wallet   MoneyTransferWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user     User                @relation("MoneyTransferWalletTxUser", fields: [userId], references: [id], onDelete: Cascade)
  transfer MoneyTransfer?      @relation(fields: [transferId], references: [id], onDelete: SetNull)
  withdrawal MoneyWalletWithdrawal?

  @@index([walletId])
  @@index([userId])
  @@index([transferId])
  @@map("money_transfer_wallet_transactions")
}

/// Customer wallet → bank withdrawal queue (manual or auto after delay).
model MoneyWalletWithdrawal {
  id                  String                      @id @default(cuid())
  userId              String
  walletTransactionId String                      @unique
  bankAccountId       String
  amount              Float
  currency            String                      @default("NGN")
  status              MoneyWalletWithdrawalStatus @default(PENDING)
  bankName            String
  accountNumber       String
  accountName         String
  bankCode            String
  paystackReference   String?
  paystackTransferCode String?
  failureReason       String?
  scheduledProcessAt  DateTime?
  processedAt         DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  rejectedAt          DateTime?
  metadata            Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  user              User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction MoneyTransferWalletTransaction @relation(fields: [walletTransactionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledProcessAt])
  @@map("money_wallet_withdrawals")
}

/// Admin support / refund cases for money transfers (separate from marketplace SupportTicket).
model MoneyTransferCase {
  id           String                 @id @default(cuid())
  ticketNumber String                 @unique
  transferId   String?
  type         MoneyTransferCaseType  @default(OTHER)
  status       TicketStatus           @default(OPEN)
  priority     TicketPriority         @default(MEDIUM)
  subject      String
  description  String
  resolution   String?
  assignedToId String?
  openedById   String
  requesterId  String?
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  resolvedAt   DateTime?

  transfer   MoneyTransfer?          @relation(fields: [transferId], references: [id], onDelete: SetNull)
  openedBy   User                    @relation("MoneyCaseOpenedBy", fields: [openedById], references: [id])
  assignedTo User?                   @relation("MoneyCaseAssignedTo", fields: [assignedToId], references: [id])
  requester  User?                   @relation("MoneyCaseRequester", fields: [requesterId], references: [id])
  notes      MoneyTransferCaseNote[]

  @@index([transferId])
  @@index([status])
  @@index([type])
  @@map("money_transfer_cases")
}

model MoneyTransferCaseNote {
  id         String   @id @default(cuid())
  caseId     String
  authorId   String
  message    String
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())

  case   MoneyTransferCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User              @relation("MoneyCaseNoteAuthor", fields: [authorId], references: [id])

  @@index([caseId])
  @@map("money_transfer_case_notes")
}

/// Known devices for money-app step-up (new device → OTP).
model MoneyTransferTrustedDevice {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  deviceLabel       String?
  platform          String?
  lastIp            String?
  lastCountryCode   String?
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@map("money_transfer_trusted_devices")
}

/// Short-lived OTP challenge after risk assessment.
model MoneyTransferStepUp {
  id                String    @id @default(cuid())
  userId            String
  action            String
  code              String
  deviceFingerprint String?
  signals           Json?
  riskScore         Int       @default(0)
  verifiedAt        DateTime?
  expiresAt         DateTime
  trustDevice       Boolean   @default(false)
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("money_transfer_step_ups")
}

/// Risk signal audit trail for fraud review.
model MoneyTransferRiskLog {
  id              String   @id @default(cuid())
  userId          String
  action          String
  riskScore       Int
  signals         Json
  blocked         Boolean  @default(false)
  stepUpRequired  Boolean  @default(false)
  ipAddress       String?
  countryCode     String?
  deviceFingerprint String?
  metadata        Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("money_transfer_risk_logs")
}

// AI Configuration Models
model AIModel {
  id               String          @id @default(cuid())
  name             String
  modelId          String // OpenRouter model ID (e.g., "anthropic/claude-sonnet-4.6")
  provider         String // Provider name (e.g., "Anthropic", "OpenAI")
  description      String?
  category         AIModelCategory // TEXT_TO_TEXT or IMAGE_TO_TEXT
  contextLength    Int?
  modality         String? // e.g., "text->text", "text+image->text"
  inputModalities  Json? // Array of input types
  outputModalities Json? // Array of output types
  pricing          Json? // { prompt: string, completion: string }

  // Configuration
  apiKey      String // OpenRouter API key
  isActive    Boolean @default(true)
  priority    Int     @default(0) // Lower number = higher priority
  maxTokens   Int?    @default(4096)
  temperature Float?  @default(0.7)
  topP        Float?  @default(1.0)

  // Status tracking
  status          AIModelStatus @default(ONLINE)
  lastHealthCheck DateTime?
  quotaUsage      Float         @default(0) // Percentage
  latency         Int? // in milliseconds

  // Usage limits
  hourlyQuotaLimit   Int? // Requests per hour
  dailyQuotaLimit    Int? // Requests per day
  currentHourlyUsage Int      @default(0)
  currentDailyUsage  Int      @default(0)
  lastQuotaReset     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usageLogs      AIUsageLog[]
  configurations AIConfiguration[]

  @@index([category, isActive, priority])
  @@index([status])
  @@map("ai_models")
}

model AIConfiguration {
  id          String    @id @default(cuid())
  name        String // Configuration name (e.g., "Order Analysis", "AI Doctor", "AI Mechanic")
  description String?
  useCase     AIUseCase // ORDER_HISTORY, REPORTING, AI_DOCTOR, AI_MECHANIC, etc.

  // Model assignment
  modelId String?
  model   AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  // System prompt/architecture
  systemPrompt String @default("")

  // Tools & Functions
  enabledTools    Json? // Array of enabled tools: ["web_search", "code_interpreter", ...]
  customFunctions Json? // Custom function definitions

  // Hyperparameters
  temperature Float? @default(0.7)
  maxTokens   Int?   @default(4096)
  topP        Float? @default(1.0)

  // Settings
  isActive Boolean @default(true)
  version  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([useCase, isActive])
  @@map("ai_configurations")
}

model AIUsageLog {
  id      String  @id @default(cuid())
  modelId String
  model   AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  // Request details
  category     AIModelCategory
  useCase      AIUseCase?
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  latency      Int? // in milliseconds

  // Status
  status       AIRequestStatus @default(SUCCESS)
  errorMessage String?

  // Cost tracking
  estimatedCost Float?

  createdAt DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([useCase, createdAt])
  @@map("ai_usage_logs")
}

enum AIModelCategory {
  TEXT_TO_TEXT
  IMAGE_TO_TEXT
}

enum AIModelStatus {
  ONLINE
  OFFLINE
  ISSUES
  RATE_LIMITED
}

enum AIUseCase {
  ORDER_HISTORY
  REPORTING
  AI_DOCTOR
  AI_MECHANIC
  GENERAL_ANALYSIS
  SMART_SHOP
  USER_ANALYTICS
  PRESCRIPTION_ANALYSIS
  HEALTH_SUMMARY
  CUSTOM
}

enum AIRequestStatus {
  SUCCESS
  FAILED
  RATE_LIMITED
  TIMEOUT
}

model UserActivity {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)

  // Activity Type
  activityType UserActivityType

  // Module Context
  module Module? // PHARMACY, GROCERY, FOOD, AUTO_PARTS

  // Search Activity
  searchQuery        String?
  searchFilters      Json? // Applied filters, categories, etc.
  searchResultsCount Int?
  searchImageUrl     String? // For image-based searches (auto parts)

  // View/Browse Activity
  viewedItemId   String?
  viewedItemType String? // product, medicine, restaurant, etc.
  viewedItemName String?
  viewDuration   Int? // Time spent viewing in seconds

  // Purchase Activity
  orderId        String?
  orderTotal     Float?
  itemsPurchased Json? // Array of purchased items
  purchaseModule Module?

  // Time Tracking
  sessionStartTime DateTime?
  sessionEndTime   DateTime?
  timeSpentSeconds Int? // Total time spent in this activity

  // Location Context
  latitude     Float?
  longitude    Float?
  locationName String?

  // Device & Session Info
  deviceInfo Json?
  sessionId  String?

  // Additional Metadata
  metadata Json? // Any additional context data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, activityType])
  @@index([userId, module])
  @@index([userId, createdAt])
  @@index([module, activityType])
  @@map("user_activities")
}

enum UserActivityType {
  SEARCH
  VIEW_ITEM
  ADD_TO_CART
  PURCHASE
  SESSION_START
  SESSION_END
  SCREEN_VIEW
  BUTTON_CLICK
  IMAGE_SEARCH
  PRESCRIPTION_UPLOAD
  AI_CONSULTATION
  MEAL_PLANNER
  SMART_CART_AI
  REORDER_LAST
  FLASH_DEAL_VIEW
  SPECIAL_OFFER_VIEW
  VEHICLE_ASSIST
  VENDOR_PRODUCT_AI
}

