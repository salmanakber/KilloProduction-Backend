  title            String
  message          String
  isRead           Boolean   @default(false)
  sentAt           DateTime  @default(now())
  readAt           DateTime?

  mechanic       User                   @relation("MechanicNotifications", fields: [mechanicId], references: [id], onDelete: Cascade)
