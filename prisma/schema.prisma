/// Admin “system notice” broadcasts (maintenance, service updates, etc.) — separate from marketing campaigns.
model NotificationCampaign {
  id               String    @id @default(cuid())
  title            String
  message          String
  /// PUSH | EMAIL | SMS | IN_APP
  type             String
  status           String    @default("DRAFT")
  targetUserTypes  String[]  @default([])
  targetModules    String[]  @default([])
  targetUserCount  Int       @default(0)
  scheduledAt      DateTime?
  sentAt           DateTime?
  imageUrl         String?
  actionUrl        String?
  sentCount        Int       @default(0)
  deliveredCount   Int       @default(0)
  openedCount      Int       @default(0)
  clickedCount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String
  createdBy        User      @relation("NotificationCampaignCreator", fields: [createdById], references: [id])

  @@index([status])
  @@map("notification_campaigns")
}
