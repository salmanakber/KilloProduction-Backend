generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:5432/killo_super_app"
}

model Currency {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  symbol        String
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  exchangeRate  Float    @default(1.0)
  decimalPlaces Int      @default(2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("currencies")
}

model User {
  id                      String                    @id @default(cuid())
  phone                   String?                   @unique
  email                   String?                   @unique
  name                    String?
  avatar                  String?
  role                    UserRole                  @default(CUSTOMER)
  isVerified              Boolean                   @default(false)
  isActive                Boolean                   @default(true)
  language                String                    @default("en")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  resetToken              String?
  resetTokenExpiry        DateTime?
  status                  UserStatus                @default(PENDING)
  password                String?
  lastLoginAt             DateTime?
  deletedAt               DateTime?
  loginFailedAttempts     Int       @default(0)
  lockedUntil             DateTime?
  abTestParticipations    ABTestParticipant[]       @relation("UserABTestParticipations")
  createdABTests          ABTest[]                  @relation("ABTestCreator")
  addresses               Address[]
  adminProfile            AdminProfile?             @relation("AdminProfile")
  auditLogs               AuditLog[]                @relation("AuditLogs")
  autoPartsStore          AutoPartsStore?
  createdAutomations      AutomationRule[]          @relation("AutomationCreator")
  bankAccounts            BankAccount[]             @relation("UserBankAccounts")
  campaignParticipations  CampaignParticipant[]     @relation("UserCampaignParticipations")
  carts                   Cart[]
  communicationLogs       CommunicationLog[]        @relation("UserCommunicationLogs")
  customerConversations   Conversation[]            @relation("CustomerConversations")
  riderConversations      Conversation[]            @relation("RiderConversations")
  vendorConversations     Conversation[]            @relation("VendorConversations")
  createdCoupons          CouponTemplate[]          @relation("CouponCreator")
  couponUsages            CouponUsage[]             @relation("UserCouponUsages")
  courierBookings         CourierBooking[]          @relation("CourierCustomer")
  riderBookings           CourierBooking[]          @relation("CourierRider")
  behaviorEvents          CustomerBehaviorEvent[]   @relation("UserBehaviorEvents")
  interestProfiles        CustomerInterestProfile[] @relation("UserInterestProfiles")
  segmentMemberships      CustomerSegmentMember[]   @relation("UserSegmentMemberships")
  deliverySchedules       DeliverySchedule[]
  savedMealPlans          SavedMealPlan[]
  emailLogs               EmailLog[]                @relation("UserEmailLogs")
  favoriteRestaurants     FavoriteRestaurant[]
  favoriteGroceryStores   FavoriteGroceryStore[]
  customizations          FoodCustomization[]
  groceryStore            GroceryStore?
  loyaltyPoints           LoyaltyPoint[]
  loyaltyTransactions     LoyaltyTransaction[]      @relation("UserLoyaltyTransactions")
  createdCampaigns        MarketingCampaign[]       @relation("CampaignCreator")
  notificationCampaignsCreated NotificationCampaign[] @relation("NotificationCampaignCreator")
  medicineReminders       MedicineReminder[]
  sentMessages            Message[]                 @relation("SentMessages")
  milestoneProgress       MilestoneProgress[]       @relation("UserMilestoneProgress")
  notifications           Notification[]
  customerOrders          Order[]                   @relation("CustomerOrders")
  prescriptionQueues      PrescriptionQueue[]
  riderDeliveries         Order[]                   @relation("RiderDeliveries")
  vendorOrders            Order[]                   @relation("VendorOrders")
  otps                    Otp[]
  partOffers              PartOffer[]
  partOfferMechanics      PartOffer[]               @relation("PartOfferMechanic")
  partRequests            PartRequest[]
  paymentMethods          PaymentMethod[]
  payments                Payment[]
  paymentProcessingLedgers PaymentProcessingLedger[]
  consultations           PharmConsultation[]       @relation("ConsumerConsultations")
  pharmacy                Pharmacy?
  pharmacyChats           PharmacyChat[]
  autoPartsChatsAsUser    AutoPartsChat[]           @relation("AutoPartsChatUser")
  autoPartsChatsAsVendor  AutoPartsChat[]           @relation("AutoPartsChatVendor")
  autoPartsChatMessages   AutoPartsChatMessage[]    @relation("AutoPartsChatMessageSender")
  prescriptions           Prescription[]
  vendorProducts          Product[]                 @relation("VendorProducts")
  referralCodes           ReferralCode[]            @relation("UserReferralCodes")
  referralRewards         ReferralReward[]          @relation("UserReferralRewards")
  referredBy              Referral[]                @relation("ReferredUser")
  referrals               Referral[]                @relation("ReferrerUser")
  reorderSuggestions      ReorderSuggestion[]
  restaurant              Restaurant?
  receivedReviews         Review[]                  @relation("ReviewTarget")
  reviews                 Review[]
  rewardRedemptions       RewardRedemption[]        @relation("UserRedemptions")
  rideBids                RideBid[]                 @relation("RiderBids")
  courierBids             CourierBid[]              @relation("CourierBids")
  serviceAreas            ServiceArea[]             @relation("RiderServiceAreas")
  customerRideBookings    RideBooking[]             @relation("CustomerRideBookings")
  riderRideBookings       RideBooking[]             @relation("RiderBookings")
  rideMessages            RideMessage[]             @relation("RideMessageSender")
  riderCashouts           RiderCashout[]            @relation("RiderCashouts")
  riderCommissions        RiderCommission[]         @relation("RiderCommissions")
  riderEarnings           RiderEarning[]            @relation("RiderEarnings")
  riderProfile            RiderProfile?
  supportTickets          SupportTicket[]
  supportTicketReplies    SupportTicketReply[]
  transactions            Transaction[]
  achievements            UserAchievement[]         @relation("UserAchievements")
  userProfile             UserProfile?
  userSettings            UserSettings?
  vendorBankAccounts      VendorBankAccount[]       @relation("VendorBankAccounts")
  vendorCommissions       VendorCommission[]        @relation("VendorCommissions")
  customerTaxes           CustomerTax[]             @relation("CustomerTaxes")
  vendorProfile           VendorProfile?            @relation("UserVendorProfile")
  vendorWithdrawals       VendorWithdrawal[]        @relation("VendorWithdrawals")
  walletTransactions      WalletTransaction[]       @relation("UserWalletTransactions")
  wallet                  Wallet?
  wholesaler              Wholesaler?
  sosAlertsAsCustomer     SOSAlert[]                @relation("SOSCustomer")
  sosAlertsAsRider        SOSAlert[]                @relation("SOSRider")
  appRatings              AppRating[]               @relation("UserAppRatings")
  mechanicProfile         MechanicProfile[]
  mechanicServiceRequests MechanicServiceRequest[]  @relation("CustomerServiceRequests")
  mechanicOffers          MechanicOffer[]           @relation("MechanicOffers")
  customerQuotes          MechanicQuote[]           @relation("CustomerQuotes")
  mechanicQuotes          MechanicQuote[]           @relation("MechanicQuotes")
  mechanicNotifications   MechanicNotification[]    @relation("MechanicNotifications")
  kycRejections           KycRejection[]            @relation("KycRejections")
  userKycRejections       KycRejection[]            @relation("UserKycRejections")
  sentMoneyTransfers            MoneyTransfer[]            @relation("MoneyTransferSender")
  receivedMoneyTransfers        MoneyTransfer[]            @relation("MoneyTransferReceiver")
  moneyTransferWallets            MoneyTransferWallet[]
  moneyTransferWalletTransactions MoneyTransferWalletTransaction[] @relation("MoneyTransferWalletTxUser")
  moneyScheduledTransfersOwner  MoneyScheduledTransfer[]   @relation("MoneyScheduledOwner")
  moneyScheduledAsRecipient     MoneyScheduledTransfer[]   @relation("MoneyScheduledReceiver")
  moneyRateAlerts               MoneyRateAlert[]           @relation("MoneyRateAlerts")
  moneyTransferCasesOpened      MoneyTransferCase[]        @relation("MoneyCaseOpenedBy")
  moneyTransferCasesAssigned    MoneyTransferCase[]        @relation("MoneyCaseAssignedTo")
  moneyTransferCasesAsRequester MoneyTransferCase[]        @relation("MoneyCaseRequester")
  moneyTransferCaseNotes        MoneyTransferCaseNote[]    @relation("MoneyCaseNoteAuthor")
  moneyWalletWithdrawals        MoneyWalletWithdrawal[]
  moneyTransferTrustedDevices   MoneyTransferTrustedDevice[]
  moneyTransferRiskLogs         MoneyTransferRiskLog[]
  moneyTransferStepUps          MoneyTransferStepUp[]
  vtpassTransactions            VtpassTransaction[]
  userActivities          UserActivity[]            @relation("UserActivities")
  specialOfferVendors     SpecialOfferVendor[]
  specialOfferSubmissions SpecialOfferSubmission[]
  healthVitals            HealthVital?
  healthLogs              HealthLog[]              @relation("UserHealthLogs")
  healthLabResults        HealthLabResult[]         @relation("UserHealthLabResults")
  doctorVisits            DoctorVisit[]             @relation("UserDoctorVisits")
  healthSummaries         HealthSummary[]           @relation("UserHealthSummaries")
  /// Aggregate of Review rows where this user is the rated party (targetType CUSTOMER)
  customerTargetRating       Float @default(0)
  customerTargetReviewCount  Int   @default(0)

  @@map("users")
}

model Otp {
  id        String   @id @default(cuid())
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
  @@index([email])
  @@map("otps")
}

model UserProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  firstName        String?
  lastName         String?
  dateOfBirth      DateTime?
  bodyTemp         String?
  bodyBp           String?
  latitude         Float?
  longitude        Float?
  city             String?
  country          String?
  lastLocationAt   DateTime?
  gender           Gender?
  bio                String?
  profileImage       String?
  emergencyContact   String?
  residentialAddress String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  pushNotifications    Boolean  @default(true)
  emailNotifications   Boolean  @default(true)
  smsNotifications     Boolean  @default(true)
  locationTracking     Boolean  @default(true)
  dataSharing          Boolean  @default(false)
  language             String   @default("en")
  currency             String   @default("USD")
  theme                String   @default("light")
  autoReorder          Boolean  @default(false)
  deliveryInstructions String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deviceTokens         Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Address {
  id           String      @id @default(cuid())
  userId       String
  type         AddressType @default(OTHER)
  title        String
  street       String
  city         String
  state        String
  country      String
  postalCode   String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean     @default(false)
  instructions String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@map("addresses")
}

model CustomerSegment {
  id               String                  @id @default(cuid())
  name             String
  description      String?
  segmentType      SegmentType
  conditions       Json
  isActive         Boolean                 @default(true)
  isDynamic        Boolean                 @default(true)
  priority         Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  CampaignSegments CampaignSegments[]
  members          CustomerSegmentMember[]

  @@map("customer_segments")
}

model CustomerSegmentMember {
  id        String          @id @default(cuid())
  segmentId String
  userId    String
  joinedAt  DateTime        @default(now())
  leftAt    DateTime?
  isActive  Boolean         @default(true)
  segment   CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user      User            @relation("UserSegmentMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([segmentId, userId])
  @@map("customer_segment_members")
}

model CustomerBehaviorEvent {
  id         String            @id @default(cuid())
  userId     String
  eventType  BehaviorEventType
  module     Module?
  entityId   String?
  entityType String?
  properties Json?
  sessionId  String?
  deviceInfo Json?
  location   Json?
  timestamp  DateTime          @default(now())
  user       User              @relation("UserBehaviorEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([timestamp])
  @@map("customer_behavior_events")
}

model CustomerInterestProfile {
  id               String    @id @default(cuid())
  userId           String
  module           Module
  category         String?
  interestScore    Float     @default(0)
  interactionCount Int       @default(0)
  lastInteraction  DateTime?
  purchaseCount    Int       @default(0)
  totalSpent       Float     @default(0)
  avgOrderValue    Float     @default(0)
  conversionRate   Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation("UserInterestProfiles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, category])
  @@map("customer_interest_profiles")
}

model MarketingCampaign {
  id                String                  @id @default(cuid())
  name              String
  description       String?
  type              CampaignType
  status            CampaignStatus          @default(DRAFT)
  channels          Json
  content           Json
  isABTest          Boolean                 @default(false)
  abTestId          String?
  schedule          Json
  startDate         DateTime?
  endDate           DateTime?
  timezone          String                  @default("UTC")
  totalSent         Int                     @default(0)
  totalDelivered    Int                     @default(0)
  totalOpened       Int                     @default(0)
  totalClicked      Int                     @default(0)
  totalConverted    Int                     @default(0)
  totalRevenue      Float                   @default(0)
  priority          Int                     @default(0)
  budget            Float?
  costPerSend       Float                   @default(0)
  createdById       String
  sentAt            DateTime?
  completedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  CampaignSegments  CampaignSegments[]
  analytics         CampaignAnalytics[]
  metrics           CampaignMetrics?
  participants      CampaignParticipant[]
  targetAudience    CampaignTargetAudience?
  communicationLogs CommunicationLog[]
  emailLogs         EmailLog[]
  abTest            ABTest?                 @relation(fields: [abTestId], references: [id])
  createdBy         User                    @relation("CampaignCreator", fields: [createdById], references: [id])
  notifications     Notification[]          @relation("CampaignNotifications")

  @@map("marketing_campaigns")
}

model CampaignTargetAudience {
  id         String            @id @default(cuid())
  campaignId String            @unique
  userType   Json
  modules    Json
  segments   Json
  totalUsers Int
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_target_audience")
}

model CampaignMetrics {
  id           String            @id @default(cuid())
  campaignId   String            @unique
  sent         Int               @default(0)
  delivered    Int               @default(0)
  opened       Int               @default(0)
  clicked      Int               @default(0)
  converted    Int               @default(0)
  revenue      Float             @default(0)
  unsubscribed Int               @default(0)
  bounced      Int               @default(0)
  campaign     MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_metrics")
}

model CampaignParticipant {
  id              String            @id @default(cuid())
  campaignId      String
  userId          String
  variant         String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  convertedAt     DateTime?
  conversionValue Float?
  unsubscribedAt  DateTime?
  createdAt       DateTime          @default(now())
  campaign        MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user            User              @relation("UserCampaignParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_participants")
}

model ABTest {
  id               String              @id @default(cuid())
  name             String
  description      String?
  hypothesis       String?
  status           ABTestStatus        @default(DRAFT)
  trafficSplit     Json
  primaryMetric    String
  secondaryMetrics Json?
  confidenceLevel  Float               @default(95)
  minSampleSize    Int                 @default(100)
  maxDuration      Int?
  winningVariant   String?
  significance     Float?
  results          Json?
  startDate        DateTime?
  endDate          DateTime?
  createdById      String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  participants     ABTestParticipant[]
  variants         ABTestVariant[]
  createdBy        User                @relation("ABTestCreator", fields: [createdById], references: [id])
  campaigns        MarketingCampaign[]

  @@map("ab_tests")
}

model ABTestVariant {
  id        String   @id @default(cuid())
  name      String
  config    Json?
  abTestId  String
  createdAt DateTime @default(now())
  abTest    ABTest   @relation(fields: [abTestId], references: [id], onDelete: Cascade)

  @@map("ab_test_variants")
}

model ABTestParticipant {
  id              String    @id @default(cuid())
  testId          String
  userId          String
  variant         String
  assignedAt      DateTime  @default(now())
  convertedAt     DateTime?
  conversionValue Float?
  test            ABTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  user            User      @relation("UserABTestParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@map("ab_test_participants")
}

model CommunicationLog {
  id               String               @id @default(cuid())
  userId           String
  campaignId       String?
  channel          CommunicationChannel
  messageType      String
  subject          String?
  content          String
  status           CommunicationStatus
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  failedAt         DateTime?
  errorMessage     String?
  externalId       String?
  phoneNumber      String?
  emailAddress     String?
  deviceToken      String?
  trackingPixel    String?
  clickTrackingUrl String?
  unsubscribeUrl   String?
  createdAt        DateTime             @default(now())
  campaign         MarketingCampaign?   @relation(fields: [campaignId], references: [id])
  user             User                 @relation("UserCommunicationLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
  @@index([campaignId])
  @@map("communication_logs")
}

model CouponTemplate {
  id                   String             @id @default(cuid())
  name                 String
  description          String?
  type                 CouponType
  discountType         PromoType
  discountValue        Float
  maxUsageTotal        Int?
  maxUsagePerUser      Int?
  currentUsage         Int                @default(0)
  minOrderAmount       Float?
  maxDiscount          Float?
  applicableModules    Json?
  applicableCategories Json?
  applicableProducts   Json?
  codePrefix           String?
  codeLength           Int                @default(8)
  codePattern          String?
  validFrom            DateTime
  validUntil           DateTime
  isActive             Boolean            @default(true)
  createdById          String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  generations          CouponGeneration[]
  createdBy            User               @relation("CouponCreator", fields: [createdById], references: [id])
  usages               CouponUsage[]

  @@map("coupon_templates")
}

model CouponGeneration {
  id             String         @id @default(cuid())
  templateId     String
  batchName      String?
  quantity       Int
  generatedCodes Json
  generatedAt    DateTime       @default(now())
  expiresAt      DateTime?
  template       CouponTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("coupon_generations")
}

model CouponUsage {
  id             String         @id @default(cuid())
  templateId     String
  userId         String
  couponCode     String
  orderId        String?
  discountAmount Float
  usedAt         DateTime       @default(now())
  template       CouponTemplate @relation(fields: [templateId], references: [id])
  user           User           @relation("UserCouponUsages", fields: [userId], references: [id])

  @@unique([couponCode, userId])
  @@map("coupon_usages")
}

model ReferralCode {
  id             String           @id @default(cuid())
  userId         String
  code           String           @unique
  type           ReferralType     @default(GENERAL)
  module         Module?
  referrerReward Json
  referredReward Json
  maxUses        Int?
  currentUses    Int              @default(0)
  validFrom      DateTime         @default(now())
  validUntil     DateTime?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation("UserReferralCodes", fields: [userId], references: [id], onDelete: Cascade)
  rewards        ReferralReward[]

  @@map("referral_codes")
}

model ReferralReward {
  id             String               @id @default(cuid())
  referralCodeId String
  referrerId     String
  referredId     String
  rewardType     RewardType
  rewardValue    Float
  status         ReferralRewardStatus @default(PENDING)
  conditionMet   Boolean              @default(false)
  conditionType  String?
  conditionValue Float?
  processedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  referralCode   ReferralCode         @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referrer       User                 @relation("UserReferralRewards", fields: [referrerId], references: [id])

  @@map("referral_rewards")
}

model Achievement {
  id               String            @id @default(cuid())
  name             String
  description      String
  icon             String?
  category         String
  module           Module?
  conditions       Json
  points           Int               @default(0)
  badge            String?
  rewards          Json?
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  progress      Json?
  isNotified    Boolean     @default(false)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation("UserAchievements", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Milestone {
  id           String              @id @default(cuid())
  name         String
  description  String
  category     String
  module       Module?
  levels       Json
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userProgress MilestoneProgress[]

  @@map("milestones")
}

model MilestoneProgress {
  id              String    @id @default(cuid())
  userId          String
  milestoneId     String
  currentLevel    Int       @default(0)
  currentProgress Float     @default(0)
  totalProgress   Float     @default(0)
  lastRewardLevel Int       @default(0)
  updatedAt       DateTime  @updatedAt
  milestone       Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user            User      @relation("UserMilestoneProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@map("milestone_progress")
}

model MarketingMetric {
  id            String   @id @default(cuid())
  name          String
  category      String
  module        Module?
  value         Float
  previousValue Float?
  changePercent Float?
  date          DateTime
  metadata      Json?
  createdAt     DateTime @default(now())

  @@unique([name, module, date])
  @@map("marketing_metrics")
}

model CampaignAnalytics {
  id             String            @id @default(cuid())
  campaignId     String
  date           DateTime
  sent           Int               @default(0)
  delivered      Int               @default(0)
  bounced        Int               @default(0)
  failed         Int               @default(0)
  opened         Int               @default(0)
  clicked        Int               @default(0)
  unsubscribed   Int               @default(0)
  conversions    Int               @default(0)
  revenue        Float             @default(0)
  channelMetrics Json?
  createdAt      DateTime          @default(now())
  campaign       MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@map("campaign_analytics")
}

model AutomationRule {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  category             String
  trigger              Json
  conditions           Json
  actions              Json
  isActive             Boolean               @default(true)
  priority             Int                   @default(0)
  cooldownPeriod       Int?
  maxExecutions        Int?
  totalExecutions      Int                   @default(0)
  successfulExecutions Int                   @default(0)
  failedExecutions     Int                   @default(0)
  createdById          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  executions           AutomationExecution[]
  createdBy            User                  @relation("AutomationCreator", fields: [createdById], references: [id])

  @@map("automation_rules")
}

model AutomationExecution {
  id          String          @id @default(cuid())
  ruleId      String
  userId      String?
  entityId    String?
  entityType  String?
  trigger     String
  status      ExecutionStatus
  result      Json?
  error       String?
  executedAt  DateTime        @default(now())
  completedAt DateTime?
