/// External POS / ERP connectors (food & grocery) — API keys + scoped access.
model PosIntegration {
  id             String               @id @default(cuid())
  module         PosIntegrationModule
  restaurantId   String?
  groceryStoreId String?
  restaurant     Restaurant?          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  groceryStore   GroceryStore?        @relation(fields: [groceryStoreId], references: [id], onDelete: Cascade)
  name           String
  providerSlug   String               @default("custom")
  isActive       Boolean              @default(true)
  settings       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  credentials    PosApiCredential[]

  @@index([restaurantId])
  @@index([groceryStoreId])
  @@map("pos_integrations")
}

enum PosIntegrationModule {
  FOOD
  GROCERY
}

model PosApiCredential {
  id               String         @id @default(cuid())
  integrationId    String
  integration      PosIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  /// SHA-256 hex of full API secret (never store plaintext).
  tokenFingerprint String         @unique
  /// First chars of token for dashboards, e.g. pos_sk_a1b2****
  tokenPrefix      String
  label            String?
  scopes           Json           @default("[]")
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())

  @@index([integrationId])
  @@map("pos_api_credentials")
}

