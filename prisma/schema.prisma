model CourierBooking {
  id                 String            @id @default(cuid())
  bookingNumber      String            @unique
  customerId         String
  riderId            String?
  rideTypeId         String
  riderProfileId     String?
  pickupAddress      String
  pickupLatitude     Float
  pickupLongitude    Float
  dropAddress        String
  dropLatitude       Float
  dropLongitude      Float
  distance           Float
  estimatedTime      Int
  fare               Float
  status             CourierStatus     @default(REQUESTED)
  paymentStatus      PaymentStatus     @default(PENDING)
  paymentMethod      String?
  notes              String?
  recipientName      String?
  recipientPhone     String?
  packageType        String?
  packageWeight      Float?
  isFragile          Boolean           @default(false)
  scheduledAt        DateTime?
  acceptedAt         DateTime?
  /// Rider arrived at the billable pickup wait location (customer handoff / single pickup), not vendor legs when `multiplePickupId` is used.
  arrivedAt          DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  pickupWaitingFee                 Float?
  pickupWaitingMinutesBillable     Int?
  pickupWaitingChargeNotifiedAt    DateTime?
  /// Running pickup-waiting charge while status is ARRIVED_AT_PICKUP (added to fare in near real time).
  pickupWaitingAccruedFee          Float   @default(0)
  /// Whole billable minutes already rolled into fare + accrued (incremental accrual guard).
  pickupWaitingBillableMinutesCharged Int   @default(0)
  pickupWaitingGraceNotified50At   DateTime?
  pickupWaitingGraceNotified90At   DateTime?
  /// Append-only style events for analytics (grace warnings, accrual bumps).
  pickupWaitingBreakdown           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customerRating     Int?
  riderRating        Int?
  customerReview     String?
  riderReview        String?
  pickupId           String?
  orderId            String? // Optional link to order for pharmacy cart deliveries
  module             String? // RIDE, FOOD, GROCERY, PHARMACY, AUTO_PARTS - to distinguish booking types
  customer           User              @relation("CourierCustomer", fields: [customerId], references: [id])
  rider              User?             @relation("CourierRider", fields: [riderId], references: [id])
  riderProfile       RiderProfile?     @relation("RiderProfileToCourierBooking", fields: [riderProfileId], references: [id])
  rideType           RideType          @relation(fields: [rideTypeId], references: [id])
  trackingUpdates    CourierTracking[]
  supplierOrders     SupplierOrder[]   @relation("SupplierOrderCourier")
  bids               CourierBid[]
  deliveryQueues     DeliveryQueue[]
  pharmacyPickups    PharmacyPickup[] // Multiple pharmacy pickups for multi-vendor orders
  rideMessages       RideMessage[]
  courierPromoUsages PromoCodeUsage[]  @relation("CourierPromoUsages")
  multiplePickups    MultiplePickup[]
  riderCommissions   RiderCommission[]

  @@map("courier_bookings")
}

model MultiplePickup {
  id               String  @id @default(cuid())
  courierBookingId String? // Optional - can be created later when rider is assigned
  orderId          String?

  // Store identification - at least one must be set
  restaurantId   String? // For food orders
  groceryStoreId String? // For grocery orders
  pharmacyId     String? // For pharmacy orders (future support)

  // Store information (denormalized for performance)
  storeName      String // Generic name (restaurantName, storeName, etc.)
  storeAddress   String
  storeLatitude  Float
  storeLongitude Float
  module         String? // GROCERY, FOOD, PHARMACY - for identification

  // Route data
  sequence             Int    @default(1) // Order of pickup in optimized route
  distanceFromPrevious Float? // Distance from previous pickup (km)
  durationFromPrevious Int? // Duration from previous pickup (seconds)

  // Route metadata (stored at order level, but can be per-pickup for flexibility)
  totalRouteDistance   Float? // Total route distance (km) - stored here for reference
  totalRouteDuration   Int? // Total route duration (seconds)
  routePolyline        String? // Encoded polyline for this segment
  estimatedArrivalTime DateTime? // Estimated arrival time at this pickup

  // Status tracking
  status     String    @default("PENDING") // PENDING, PICKED_UP, SKIPPED, CANCELLED
  pickedUpAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  courierBooking CourierBooking? @relation(fields: [courierBookingId], references: [id], onDelete: Cascade)
  restaurant     Restaurant?     @relation(fields: [restaurantId], references: [id])
  groceryStore   GroceryStore?   @relation(fields: [groceryStoreId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])

  @@map("multiple_pickups")
}

