enum TemplateModule {
  GLOBAL
  PHARMACY
  FOOD
  GROCERY
  AUTO_PARTS
  RIDING
  DELIVERY
  ADMIN
}

enum EmailTemplateCategory {
  VERIFICATION
  NOTIFICATION
  MARKETING
  TRANSACTIONAL
  SUPPORT
  WELCOME
  ORDER_CONFIRMATION
  ORDER_STATUS
  PAYMENT
  ACCOUNT
  RESET_PASSWORD
  INVITATION
  REMINDER
  PROMOTIONAL
  NEWSLETTER
  FEEDBACK
}

enum SmsTemplateCategory {
  OTP
  NOTIFICATION
  ALERT
  REMINDER
  ORDER_UPDATE
  PAYMENT
  DELIVERY
  VERIFICATION
  MARKETING
  PROMOTIONAL
}

model EmailTemplate {
  id          String                @id @default(cuid())
  templateKey String                @unique // Immutable unique identifier (e.g., "PHARMACY_ORDER_CONFIRMATION")
  name        String // Human-readable name (can be changed)
  subject     String
  htmlContent String                @db.Text
  textContent String?               @db.Text
  variables   Json // Array of variable names that can be used in template
  category    EmailTemplateCategory
  module      TemplateModule        @default(GLOBAL) // Which module this template belongs to
  description String?
  isActive    Boolean               @default(true)
  isDefault   Boolean               @default(false) // If true, this is the default template for this category+module
  isSystem    Boolean               @default(false) // If true, cannot be deleted (only deactivated)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   String?
  lastUsedAt  DateTime?

  @@unique([category, module, templateKey]) // Only one default per category+module
  @@index([templateKey])
  @@index([module, category])
  @@map("email_templates")
}

model SmsTemplate {
  id          String              @id @default(cuid())
  templateKey String              @unique // Immutable unique identifier (e.g., "PHARMACY_ORDER_SHIPPED")
  name        String // Human-readable name (can be changed)
  content     String              @db.Text
  variables   Json // Array of variable names that can be used in template
  category    SmsTemplateCategory
  module      TemplateModule      @default(GLOBAL) // Which module this template belongs to
  description String?
  isActive    Boolean             @default(true)
  isDefault   Boolean             @default(false) // If true, this is the default template for this category+module
  isSystem    Boolean             @default(false) // If true, cannot be deleted (only deactivated)
  maxLength   Int                 @default(160) // SMS character limit
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   String?
  lastUsedAt  DateTime?

  @@unique([category, module, isDefault]) // Only one default per category+module
  @@index([templateKey])
  @@index([module, category])
  @@map("sms_templates")
}

