  medicineId   String?
  medicineName String
  dosage       String
  frequency    String
  times        Json?
  duration     Int?
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  medicine     Medicine? @relation(fields: [medicineId], references: [id])
