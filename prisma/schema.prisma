model SpecialOffer {
  id               String                     @id @default(cuid())
  title            String
  subtitle         String?
  description      String?
  discountType     DiscountType               @default(PERCENTAGE)
  discountValue    Float
  discountFundedBy SpecialOfferDiscountFunder @default(PLATFORM)
  validFrom        DateTime
  validUntil       DateTime
  imageUrl         String?
  bannerImageUrl   String? // Banner image for promotional display
  isActive         Boolean                    @default(true)
  targetAudience   Json? // Target specific user segments
  conditions       Json? // Terms and conditions
  maxUses          Int? // Maximum number of uses
  usedCount        Int                        @default(0)
  // Multi-module support
  module           SpecialOfferModule         @default(PHARMACY)

  // Optional: legacy pharmacy-specific offer
  pharmacyId String? // If offer is specific to a pharmacy (legacy)

  // Location targeting (if set, only vendors near this location should participate)
  locationState     String?
  locationLatitude  Float?
  locationLongitude Float?
  locationRadiusKm  Float? // e.g. 25 = 25km

  // Vendor participation limits
  maxVendors Int?

  // Participation features
  enableInvitations Boolean @default(true)
  enablePaidSlots   Boolean @default(false)
  slotPrice         Float?
  maxPaidSlots      Int?
  enableAiSelection Boolean @default(false)

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  pharmacy    Pharmacy?                @relation(fields: [pharmacyId], references: [id])
  vendors     SpecialOfferVendor[]
  submissions SpecialOfferSubmission[]
  reports     SpecialOfferReport[]

  @@map("special_offers")
}

enum SpecialOfferModule {
  PHARMACY
  GROCERY
  FOOD
  AUTO_PARTS
}

enum SpecialOfferVendorSource {
  INVITED
  PAID_SLOT
  AI_SELECTED
}

enum SpecialOfferVendorStatus {
  INVITED
  ACCEPTED
  DECLINED
  PURCHASED_SLOT
  SUBMITTED_PRODUCT
  APPROVED
  REJECTED
}

enum SpecialOfferDiscountFunder {
  PLATFORM
  VENDOR
}

model SpecialOfferVendor {
  id          String                   @id @default(cuid())
  offerId     String
  vendorId    String // User.id (vendor user)
  module      SpecialOfferModule
  source      SpecialOfferVendorSource
  status      SpecialOfferVendorStatus @default(INVITED)
  invitedAt   DateTime                 @default(now())
  respondedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  offer  SpecialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  vendor User         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([offerId, vendorId])
  @@map("special_offer_vendors")
}

model SpecialOfferSubmission {
  id        String             @id @default(cuid())
  offerId   String
  vendorId  String // User.id
  module    SpecialOfferModule
  productId String // Module-specific product identifier
  data      Json?
  status    String             @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  offer  SpecialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  vendor User         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("special_offer_submissions")
}

/// Aggregated reporting per offer/vendor, populated by cron
model SpecialOfferReport {
  id               String             @id @default(cuid())
  offerId          String
  vendorId         String? // null = overall summary (optional)
  module           SpecialOfferModule
  totalOrders      Int
  totalUnits       Int
  grossSales       Float
  discountPlatform Float              @default(0)
  discountVendor   Float              @default(0)
  createdAt        DateTime           @default(now())

  offer SpecialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, vendorId])
  @@map("special_offer_reports")
}

model PrescriptionQueue {
  id                 String                  @id @default(cuid())
  customerId         String
  prescriptionId     String?
  pharmacyId         String
