  /// Target rides upper clamp (default 12).
  riderPeakBonusMaxTargetRides       Int     @default(12)
  /// Target rides formula: round(base + peakScore × scale), then clamped (defaults 2 + peak×2).
  riderPeakBonusTargetBase           Float   @default(2)
  riderPeakBonusTargetPeakScale      Float   @default(2)
  /// Share of (incremental rides × avg commission profit) used as bonus cap, 0–1 (default 0.7).
  riderPeakBonusBonusProfitShare     Float   @default(0.7)
  /// Commission discount: min(50, round((peakScore − 1) × factor)) (default factor 25).
  riderPeakBonusCommissionPeakFactor Float   @default(25)
  /// Model: baseline completions per online rider per hour (default 0.35).
  riderPeakBonusBaselineUtilPerHour  Float   @default(0.35)
  /// Model: expected completions per online rider per hour under bonus (default 0.9).
  riderPeakBonusExpectedUtilPerHour  Float   @default(0.9)
  /// Customer app OAuth (Google / Facebook). Shape: { google?: { webClientId, iosClientId, androidClientId }, facebook?: { appId, appSecret } }
  customerOAuth                      Json?

  /// Money transfer PDF receipts: Meta Cloud API + optional Twilio WhatsApp / SMS fallback.
  moneyReceiptWhatsapp Json?

  @@map("system_settings")
}

