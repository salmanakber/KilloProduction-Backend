  @@index([serviceRequestId])
  @@index([isRead])
  @@index([sentAt])
  @@map("mechanic_notifications")
}

// Mechanic Quote - Separate from service requests and offers
// Customer requests a quote, mechanic submits quote with pricing, customer accepts → service request created
model MechanicQuote {
  id                String       @id @default(cuid())
  customerId        String
  mechanicId        String
  vehicleMake       String
  vehicleModel      String
  vehicleYear       String?
  issueDescription  String
  customerLatitude  Float?
  customerLongitude Float?
  customerAddress   String?
  customerCity      String?
  urgency           UrgencyLevel @default(MEDIUM)

  // Quote details from mechanic
  partsList      Json? // Array of parts with quantities and prices (optional)
  serviceCharges Float? // Labor/service charges (null until mechanic submits pricing)
  diagnosticFee  Float? // Diagnostic fee if applicable
  totalAmount    Float? // Total (parts + service + diagnostic) (null until mechanic submits pricing)
  estimatedTime  String? // e.g., "2-3 hours", "1 day"
  warranty       String? // Warranty information
  notes          String? // Additional notes from mechanic

  status           MechanicQuoteStatus @default(PENDING)
  expiresAt        DateTime?
  acceptedAt       DateTime? // When customer accepts the quote
  serviceRequestId String?             @unique // Created service request ID after quote acceptance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer       User                    @relation("CustomerQuotes", fields: [customerId], references: [id], onDelete: Cascade)
  mechanic       User                    @relation("MechanicQuotes", fields: [mechanicId], references: [id], onDelete: Cascade)
  serviceRequest MechanicServiceRequest? @relation("QuoteServiceRequests", fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([mechanicId])
  @@index([status])
  @@index([serviceRequestId])
  @@map("mechanic_quotes")
}

