# Nginx WebSocket proxy for Socket.IO on api.kilo1app.com
#
# Symptom: GET https://api.kilo1app.com/api/socketio → 200 OK
#          but mobile/socket.io-client → "Unexpected server response: 400"
#
# Add the map block once inside http { } in /etc/nginx/nginx.conf:
#
#   map $http_upgrade $connection_upgrade {
#     default upgrade;
#     ''      close;
#   }
#
# Add this location inside the api.kilo1app.com server { } block
# (before any generic location / that might swallow upgrades):

location /api/socketio {
    proxy_pass http://127.0.0.1:3000/api/socketio;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;
    proxy_read_timeout 86400s;
    proxy_send_timeout 86400s;
}

# After editing:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Verify from your machine:
#   node web/backend-data/scripts/test-socket-production.js
